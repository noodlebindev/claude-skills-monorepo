{
  "eval_id": 1,
  "eval_name": "first-run-google-gemini",
  "prompt": "distil research on ~/Research/Google Gemini",
  "assertions": [
    {"id": "playbook_exists", "text": "Produced _distilled/playbook.md", "type": "file_exists"},
    {"id": "manifest_exists", "text": "Produced _distilled/manifest.json", "type": "file_exists"},
    {"id": "manifest_valid_json", "text": "Manifest has required top-level fields", "type": "json_schema"},
    {"id": "manifest_files_have_reason", "text": "Every file entry has a 'reason' field", "type": "json_schema"},
    {"id": "manifest_files_have_contribution_type", "text": "Every file entry has a 'contribution_type' field (iter 2)", "type": "json_schema"},
    {"id": "manifest_valid_verdicts", "text": "All verdicts are kept | partial | archived | quarantined", "type": "json_schema"},
    {"id": "manifest_valid_contribution_types", "text": "All contribution_types are valid (iter 2)", "type": "json_schema"},
    {"id": "at_least_one_kept", "text": "At least one file was kept", "type": "behavior"},
    {"id": "no_files_deleted", "text": "File count preserved", "type": "behavior"},
    {"id": "playbook_size_in_range_or_justified", "text": "Playbook ≤8 KB, OR justified (iter 2)", "type": "size_check"},
    {"id": "no_inline_citations", "text": "No inline source citations", "type": "regex_absent"},
    {"id": "operator_first_present", "text": "Playbook uses operator-first scaffolding (iter 2)", "type": "regex_present"},
    {"id": "run_report_complete", "text": "run-report.md has all required sections", "type": "section_headings"}
  ]
}
