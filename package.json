{
  "name": "claude-skills",
  "version": "0.1.0",
  "private": true,
  "description": "Open-source monorepo of Claude skills with strong per-skill isolation",
  "license": "MIT",
  "type": "module",
  "packageManager": "pnpm@11.1.2",
  "engines": {
    "node": ">=22"
  },
  "workspaces": [
    "skills/*"
  ],
  "scripts": {
    "health": "tsx scripts/audit-skills.ts",
    "lint": "tsx scripts/lint-skills.ts",
    "index": "tsx scripts/generate-index.ts",
    "contamination": "tsx scripts/check-contamination.ts",
    "new": "tsx scripts/new-skill.ts",
    "check": "pnpm run lint && pnpm run health && pnpm run contamination",
    "test": "pnpm -r --if-present run test"
  },
  "devDependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^22.10.0",
    "js-yaml": "^4.1.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
